<!doctype html>
<html lang="nl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> | Voetbal Wedstrijden App</title>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <header class="topbar">
      <div class="container topbar-inner">
        <a class="brand" href="/">Voetbal Wedstrijden</a>
        <nav class="nav">
          <a class="<%= path === '/' ? 'active' : '' %>" href="/">Dashboard</a>
          <a class="<%= path.startsWith('/matches') ? 'active' : '' %>" href="/matches">Wedstrijden</a>
          <% if (isDeveloper) { %>
            <a class="<%= path.startsWith('/people') ? 'active' : '' %>" href="/people">Leden</a>
            <a class="<%= path === '/loyalty' ? 'active' : '' %>" href="/loyalty">Loyalty</a>
            <a class="<%= path === '/loyalty/match-points' ? 'active' : '' %>" href="/loyalty/match-points">Punten per match</a>
            <a class="<%= path === '/loyalty/member-overview' ? 'active' : '' %>" href="/loyalty/member-overview">Ledenoverzicht</a>
          <% } else { %>
            <a class="<%= path === '/loyalty/match-points' ? 'active' : '' %>" href="/loyalty/match-points">Punten per match</a>
            <a class="<%= path === '/loyalty/member-overview' ? 'active' : '' %>" href="/loyalty/member-overview">Ledenoverzicht</a>
          <% } %>
        </nav>
        <div class="mode-switch">
          <span class="mode-label">Omgeving: <strong><%= isDeveloper ? 'Ontwikkelaar' : 'Gebruiker' %></strong></span>
          <a class="mode-link <%= isUser ? 'active' : '' %>" href="<%= path %>?mode=user">Gebruiker</a>
          <a class="mode-link <%= isDeveloper ? 'active' : '' %>" href="<%= path %>?mode=developer">Ontwikkelaar</a>
        </div>
      </div>
    </header>
    <main class="container">
