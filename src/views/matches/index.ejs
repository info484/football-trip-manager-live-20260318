<%- include('../partials/header') %>

<section class="page-header page-header-with-action">
  <div>
    <h1>Wedstrijden</h1>
    <p>Beheer alle wedstrijden en puntenwaarden.</p>
  </div>
  <% if (isDeveloper) { %>
    <a class="btn" href="/matches/new">Nieuwe wedstrijd</a>
  <% } %>
</section>

<% if (message) { %>
  <div class="alert <%= messageType === 'error' ? 'alert-error' : 'alert-success' %>"><%= message %></div>
<% } %>

<section class="card">
  <form method="get" class="inline-form">
    <label>
      Status
      <select name="status" onchange="this.form.submit()">
        <option value="">Alle</option>
        <option value="open" <%= selectedStatus === 'open' ? 'selected' : '' %>>Open</option>
        <option value="closed" <%= selectedStatus === 'closed' ? 'selected' : '' %>>Afgesloten</option>
      </select>
    </label>
  </form>

  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Datum</th>
          <th>Tegenstander</th>
          <th>Locatie</th>
          <th>Punten</th>
          <th>Prijzen</th>
          <th>Status</th>
          <th>Inschr.</th>
          <% if (isDeveloper) { %>
            <th>Acties</th>
          <% } %>
        </tr>
      </thead>
      <tbody>
        <% if (matches.length === 0) { %>
          <tr>
            <td colspan="<%= isDeveloper ? 8 : 7 %>">Nog geen wedstrijden.</td>
          </tr>
        <% } %>
        <% matches.forEach((match) => { %>
          <tr>
            <td><a href="/matches/<%= match.id %>"><%= new Date(match.match_datetime).toLocaleString('nl-BE') %></a></td>
            <td><%= match.opponent %></td>
            <td><%= match.location %></td>
            <td><%= match.points_value %></td>
            <td>Bus EUR <%= Number(match.bus_price).toFixed(2) %> / All-in EUR <%= Number(match.all_in_price).toFixed(2) %></td>
            <td><span class="badge"><%= match.status %></span></td>
            <td><%= match.registrations %></td>
            <% if (isDeveloper) { %>
              <td>
                <div class="actions">
                  <a class="btn btn-small" href="/matches/<%= match.id %>/edit">Bewerk</a>
                  <form method="post" action="/matches/<%= match.id %>?_method=DELETE" onsubmit="return confirm('Wedstrijd verwijderen?');">
                    <button class="btn btn-small btn-danger" type="submit">Verwijder</button>
                  </form>
                </div>
              </td>
            <% } %>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</section>

<%- include('../partials/footer') %>
