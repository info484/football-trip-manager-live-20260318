<%- include('../partials/header') %>

<section class="page-header">
  <h1><%= title %></h1>
  <p>Stel punten (1/3/5) en prijzen in voor deze wedstrijd.</p>
</section>

<% if (errors.length > 0) { %>
  <div class="alert alert-error">
    <% errors.forEach((error) => { %>
      <p><%= error %></p>
    <% }) %>
  </div>
<% } %>

<section class="card form-card">
  <form method="post" action="<%= formAction %>">
    <div class="form-grid">
      <label>
        Datum + uur *
        <input type="datetime-local" name="matchDatetime" value="<%= match.matchDatetime || '' %>" required />
      </label>
      <label>
        Tegenstander *
        <input type="text" name="opponent" value="<%= match.opponent || '' %>" required />
      </label>
      <label>
        Locatie *
        <input type="text" name="location" value="<%= match.location || '' %>" required />
      </label>
      <label>
        Type wedstrijd
        <input type="text" name="matchType" value="<%= match.matchType || '' %>" placeholder="Competitie, beker, ..." />
      </label>
      <label>
        Puntenwaarde *
        <select name="pointsValue" required>
          <option value="1" <%= Number(match.pointsValue) === 1 ? 'selected' : '' %>>1</option>
          <option value="3" <%= Number(match.pointsValue) === 3 ? 'selected' : '' %>>3</option>
          <option value="5" <%= Number(match.pointsValue) === 5 ? 'selected' : '' %>>5</option>
        </select>
      </label>
      <label>
        Busprijs *
        <input type="number" min="0" step="0.01" name="busPrice" value="<%= match.busPrice ?? 0 %>" required />
      </label>
      <label>
        All-in prijs *
        <input type="number" min="0" step="0.01" name="allInPrice" value="<%= match.allInPrice ?? 0 %>" required />
      </label>
      <label>
        Status *
        <select name="status" required>
          <% matchStatusOptions.forEach((status) => { %>
            <option value="<%= status %>" <%= match.status === status ? 'selected' : '' %>><%= status %></option>
          <% }) %>
        </select>
      </label>
    </div>

    <div class="form-actions">
      <a class="btn btn-secondary" href="/matches">Annuleer</a>
      <button class="btn" type="submit">Opslaan</button>
    </div>
  </form>
</section>

<%- include('../partials/footer') %>
