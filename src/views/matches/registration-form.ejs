<%- include('../partials/header') %>

<section class="page-header">
  <h1><%= title %></h1>
  <p><strong><%= match.opponent %></strong> - <%= new Date(match.match_datetime).toLocaleString('nl-BE') %></p>
</section>

<% if (errors.length > 0) { %>
  <div class="alert alert-error">
    <% errors.forEach((error) => { %>
      <p><%= error %></p>
    <% }) %>
  </div>
<% } %>

<section class="card form-card">
  <form method="post" action="<%= formAction %>">
    <div class="form-grid">
      <label>
        Lid *
        <select name="personId" required>
          <option value="">Kies lid</option>
          <% people.forEach((person) => { %>
            <option value="<%= person.id %>" <%= Number(registration.personId) === Number(person.id) ? 'selected' : '' %>>
              <%= person.first_name %> <%= person.last_name %>
            </option>
          <% }) %>
        </select>
      </label>

      <label>
        Aanwezigheid *
        <select name="attendance" required>
          <% attendanceOptions.forEach((option) => { %>
            <option value="<%= option %>" <%= registration.attendance === option ? 'selected' : '' %>><%= option %></option>
          <% }) %>
        </select>
      </label>

      <label>
        Plaats *
        <select name="seatType" required>
          <% seatOptions.forEach((option) => { %>
            <option value="<%= option %>" <%= registration.seatType === option ? 'selected' : '' %>><%= option %></option>
          <% }) %>
        </select>
      </label>

      <label>
        Pakket *
        <select name="packageType" required>
          <% packageOptions.forEach((option) => { %>
            <option value="<%= option %>" <%= registration.packageType === option ? 'selected' : '' %>><%= option %></option>
          <% }) %>
        </select>
      </label>

      <label>
        Betaalmethode *
        <select name="paymentMethod" required>
          <% paymentMethodOptions.forEach((option) => { %>
            <option value="<%= option %>" <%= registration.paymentMethod === option ? 'selected' : '' %>><%= option %></option>
          <% }) %>
        </select>
      </label>

      <label>
        Betaalstatus *
        <select name="paymentStatus" required>
          <% paymentStatusOptions.forEach((option) => { %>
            <option value="<%= option %>" <%= registration.paymentStatus === option ? 'selected' : '' %>><%= option %></option>
          <% }) %>
        </select>
      </label>

      <label>
        Manuele prijs (optioneel)
        <input type="number" min="0" step="0.01" name="manualAmount" value="<%= registration.manualAmount ?? '' %>" placeholder="Leeg = automatisch" />
      </label>

      <label class="span-2">
        Opmerkingen
        <textarea name="notes" rows="3"><%= registration.notes || '' %></textarea>
      </label>
    </div>

    <p class="hint">Automatische prijs: all-in gebruikt all-in prijs van de wedstrijd, enkel bus gebruikt busprijs. Bij afwezig wordt bedrag 0 tenzij je manueel overschrijft.</p>

    <div class="form-actions">
      <a class="btn btn-secondary" href="/matches/<%= match.id %>">Annuleer</a>
      <button class="btn" type="submit">Opslaan</button>
    </div>
  </form>
</section>

<%- include('../partials/footer') %>
